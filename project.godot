; Engine configuration file.
; Atraxis — Godot 4 project file.

config_version=5

[application]

config/name="Atraxis"
config/description="Weltraum-/Systemsimulation. Foundation-Slice: Zeitdienst, Orbitkern, Registry, Bubble-Stub, Debug-Testbed."
run/main_scene="res://scenes/bootstrap/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

TimeService="*res://src/core/time/time_service.gd"
UniverseRegistry="*res://src/sim/universe/universe_registry.gd"

[physics]

common/physics_ticks_per_second=60

[rendering]

renderer/rendering_method="forward_plus"
